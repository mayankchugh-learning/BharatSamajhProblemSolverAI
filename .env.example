# =============================================================================
# BharatSolve AI — Environment Variables
# =============================================================================
# Copy this file to .env:  cp .env.example .env
# All variables are optional for local development (sensible defaults apply).

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Leave empty for in-memory storage (resets on restart).
# Set to a PostgreSQL connection string for persistent storage.
# DATABASE_URL=postgresql://user:password@localhost:5432/bharatsolve

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
# Secret used to sign session cookies. Use a strong random value in production.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=local-dev-secret-change-me

# -----------------------------------------------------------------------------
# AI Provider
# -----------------------------------------------------------------------------
# Leave empty for mock AI responses (no API key needed for local dev).
# Set to a valid OpenAI key for real AI, or "ollama" for local LLM.
# OPENAI_API_KEY=sk-...

# OpenAI model to use (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# For Ollama (free local LLM):
# OPENAI_API_KEY=ollama
# AI_INTEGRATIONS_OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2

# -----------------------------------------------------------------------------
# Web Search (supplements AI responses with real-time information)
# -----------------------------------------------------------------------------
# Set ONE of the following for web-search enriched AI responses.
# Leave both empty to skip web search (AI still works, just without internet context).

# Brave Search API (free tier: 2000 queries/month) — https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=BSA...

# Serper.dev / Google Search API (free tier: 2500 queries/month) — https://serper.dev
# SERPER_API_KEY=...

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port the server listens on (default: 3000)
PORT=3000

# Log level: trace, debug, info, warn, error, fatal (default: info in prod, debug in dev)
# LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Production Settings
# -----------------------------------------------------------------------------
# Base URL for canonical links, OG meta, sitemap, robots.txt
# BASE_URL=https://bharatsolve.ai

# Allowed CORS origin (should match your production domain)
# ALLOWED_ORIGIN=https://bharatsolve.ai

# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Resend API key for transactional emails (welcome, receipts, password reset)
# https://resend.com — free tier: 100 emails/day
# RESEND_API_KEY=re_...

# From address for emails (must be verified domain in Resend)
# EMAIL_FROM=BharatSolve AI <noreply@bharatsolve.ai>

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# Admin login credentials (required for /admin dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Optional: comma-separated user IDs (e.g. dev-user-001) — users in this list get admin
# access without entering username/password when logged in
# ADMIN_USER_IDS=dev-user-001

# -----------------------------------------------------------------------------
# Docker / PostgreSQL (used by docker-compose.yml)
# -----------------------------------------------------------------------------
# POSTGRES_PASSWORD=your-secure-password
